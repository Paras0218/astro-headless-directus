<script is:inline>
  // ============== Contact form submission ==============
  // Cloned from src/pages/hvac-form/index.astro form handler.
  // Reads window.thriveZohoForm.receiverUrl, fills attribution from
  // window.thriveAttribution (utm-capture.js), POSTs JSON to receiver,
  // fires PostHog + Google Ads conversion, redirects to /thank-you/.
  (function () {
    var form = document.getElementById('contactForm');
    if (!form) return;
    var card = form.closest('.lead-form-card');
    var successEl = card && card.querySelector('.lf-success');

    function validateField(input) {
      var ok = input.checkValidity();
      var fieldEl = input.closest('.field');
      if (fieldEl) fieldEl.classList.toggle('is-error', !ok);
      return ok;
    }
    Array.prototype.forEach.call(form.querySelectorAll('input, select'), function (el) {
      el.addEventListener('blur', function () { if (el.required) validateField(el); });
      el.addEventListener('input', function () {
        var fieldEl = el.closest('.field');
        if (fieldEl && fieldEl.classList.contains('is-error') && el.checkValidity()) {
          fieldEl.classList.remove('is-error');
        }
      });
    });

    function fillAttribution() {
      var a = window.thriveAttribution || {};
      ['utm_source','utm_medium','utm_campaign','utm_content','utm_term','gclid'].forEach(function (k) {
        var el = form.querySelector('input[name="' + k + '"]');
        if (el && a[k]) el.value = a[k];
      });
      var ref = form.querySelector('input[name="referrer"]');
      if (ref) ref.value = document.referrer || '';
    }

    function buildPayload() {
      var data = {};
      Array.prototype.forEach.call(form.elements, function (el) {
        if (!el.name || el.type === 'submit') return;
        data[el.name] = el.value || '';
      });
      data.submitted_at = new Date().toISOString();
      data.page_url = window.location.href;
      return data;
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var allOk = true;
      Array.prototype.forEach.call(form.querySelectorAll('input[required], select[required]'), function (el) {
        if (!validateField(el)) allOk = false;
      });
      if (!allOk) {
        var firstError = form.querySelector('.field.is-error input, .field.is-error select');
        if (firstError) firstError.focus();
        return;
      }
      fillAttribution();
      var btn = form.querySelector('button[type="submit"]');
      if (btn) { btn.disabled = true; btn.textContent = 'Sending…'; }

      var cfg = window.thriveZohoForm || {};
      var payload = buildPayload();

      if (window.posthog && typeof window.posthog.capture === 'function') {
        try {
          window.posthog.capture('home_form_submitted', {
            company: form.querySelector('[name="company"]').value,
            budget: form.querySelector('[name="budget"]').value,
            company_size: form.querySelector('[name="company_size"]').value,
            landing_page: 'home',
          });
        } catch (err) {}
      }
      if (window.gtag) {
        try {
          window.gtag('event', 'conversion', {
            send_to: 'AW-18163893174/thcOCN2CirEcELaHnNVD',
            value: 200.0, currency: 'USD',
          });
        } catch (err) {}
      }

      fetch(cfg.receiverUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      })
        .then(function (r) { return r.json().catch(function () { return null; }); })
        .then(function (j) {
          if (window.console && j) console.log('[Thrive form] receiver:', j);
          redirectToThankYou(j);
        })
        .catch(function (err) {
          if (window.console) console.warn('[Thrive form] submit error (still redirecting):', err);
          redirectToThankYou(null);
        });

      function redirectToThankYou(j) {
        var params = new URLSearchParams({
          source: 'form',
          first_name: payload.first_name || '',
          landing_page: 'home',
        });
        if (j && j.zoho && j.zoho.id) params.set('lead', j.zoho.id);
        window.location.href = '/thank-you/?' + params.toString();
      }
    });

    function showSuccess() {
      if (!successEl) return;
      form.hidden = true;
      successEl.hidden = false;
      if (card && card.scrollIntoView) {
        card.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    }

    var qs = new URLSearchParams(window.location.search);
    if (qs.get('submitted') === '1') showSuccess();
  })();
</script>
<script is:inline>
  // ============== Client testimonial carousel ==============
  // Auto-advances every 6s. Pauses on hover / focus inside.
  // Clicking a dot jumps to a slide and restarts the timer.
  (function () {
    var root = document.querySelector('[data-tc]');
    if (!root) return;
    var slides = root.querySelectorAll('.tc-slide');
    var dots = root.querySelectorAll('.tc-dot');
    if (!slides.length || slides.length !== dots.length) return;

    var idx = 0;
    var timer = null;
    var INTERVAL = 6000;

    function show(i) {
      idx = (i + slides.length) % slides.length;
      for (var j = 0; j < slides.length; j++) {
        slides[j].classList.toggle('is-active', j === idx);
        dots[j].classList.toggle('is-active', j === idx);
        dots[j].setAttribute('aria-selected', j === idx ? 'true' : 'false');
      }
    }
    function next() { show(idx + 1); }
    function start() { stop(); timer = window.setInterval(next, INTERVAL); }
    function stop() { if (timer) { window.clearInterval(timer); timer = null; } }

    for (var k = 0; k < dots.length; k++) {
      (function (i) {
        dots[i].addEventListener('click', function () { show(i); start(); });
      })(k);
    }
    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', start);
    root.addEventListener('focusin', stop);
    root.addEventListener('focusout', start);

    // Respect users who prefer no motion: still rotate, but no autoplay.
    if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      return;
    }
    start();
  })();
</script>
