<!-- ============== 06.7 How We Grow Your Revenue ============== -->
<section class="grow-revenue" id="grow-revenue">
  <div class="wrap">
    <div class="gr-intro">
      <div class="gr-intro-copy">
        <h2 class="section-h2 section-h2-left">{home.grow_h2}</h2>
        <Fragment set:html={home.grow_body_html} />
      </div>
      <div class="gr-intro-cluster">
        <a class="gr-logo-link" href="#grow-score" aria-label="Jump to Thrive Score">
          <img src="/assets/tools/thrive-score-logo.png" alt="Thrive Score" loading="lazy" />
        </a>
        <a class="gr-logo-link" href="#grow-stats" aria-label="Jump to Thrive Stats">
          <img src="/assets/tools/thrive-stats-logo.png" alt="Thrive Stats" loading="lazy" />
        </a>
        <a class="gr-logo-link" href="#grow-ai" aria-label="Jump to ThriveAI">
          <img src="/assets/tools/thrive-ai-logo.png" alt="ThriveAI" loading="lazy" />
        </a>
        <a class="gr-logo-link" href="#grow-growth" aria-label="Jump to Thrive Growth Formula">
          <img src="/assets/tools/thrive-growth-formula-logo.png" alt="Thrive Growth Formula" loading="lazy" />
        </a>
        <a class="gr-logo-link" href="#grow-local" aria-label="Jump to Thrive Local">
          <img src="/assets/tools/thrive-local-logo.png" alt="Thrive Local" loading="lazy" />
        </a>
      </div>
    </div>

    <div class="gr-cards">
      {toolsRendered.map((t, i) => (
        <article class:list={['gr-card', toolClasses[i % toolClasses.length]]} id={toolIds[i % toolIds.length]}>
          <div class="gr-card-copy">
            <img class="gr-card-logo" src={t.logo} alt="" loading="lazy" />
            {t.heading ? <h3 class="gr-card-h3">{t.heading}</h3> : null}
            <Fragment set:html={t.body_html} />
            <a class="gr-learn" href={t.learn_url} target="_blank" rel="noopener">LEARN MORE <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="10 8 14 12 10 16"/></svg></a>
          </div>
          <div class:list={['gr-card-visual', toolVisualClasses[i % toolVisualClasses.length]]}>
            <img src={t.visual} alt="" loading="lazy" />
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

