---
import '../styles/tw-utilities.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import {
  getHeader, getNavItems, getMegaMenus, getResultCards, getHomepage,
  getHomeResults, getHomeWins, getHomeAiv, getHomeTools, getHomeValues, getTestimonials,
} from '../lib/directus';

export const prerender = false;

const [header, navItems, megaMenus, resultCards, home, results, wins, aivCards, tools, values, testimonials] = await Promise.all([
  getHeader(), getNavItems(), getMegaMenus(), getResultCards(), getHomepage(),
  getHomeResults(), getHomeWins(), getHomeAiv(), getHomeTools(), getHomeValues(), getTestimonials(),
]);

const title = home.seo_title;
const description = home.seo_description;
const heroTrust = home.hero_trust_list.split(/\r?\n/).map((s) => s.trim()).filter(Boolean);
const valueIcons = [
  '<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>',
  '<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 4 5v7c0 5 3.5 8.5 8 10 4.5-1.5 8-5 8-10V5l-8-3z"/></svg>',
  '<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3a14 14 0 0 1 0 18"/><path d="M12 3a14 14 0 0 0 0 18"/></svg>',
  '<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>',
];
const toolClasses = ['gr-card-score', 'gr-card-stats', 'gr-card-ai', 'gr-card-growth', 'gr-card-local'];
const toolIds = ['grow-score', 'grow-stats', 'grow-ai', 'grow-growth', 'grow-local'];
const toolVisualClasses = ['gr-card-visual-score', 'gr-card-visual-stats', 'gr-card-visual-ai', 'gr-card-visual-growth', 'gr-card-visual-local'];
const toolsRendered = tools.map((t) => ({ ...t, body_html: t.body_html.includes('<p') ? t.body_html : `<p>${t.body_html}</p>` }));
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<link rel="icon" type="image/png" href="/favicon.png" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;600&family=Caveat:wght@500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://use.typekit.net/onm8nad.css" />
<link rel="stylesheet" href="/fonts/proximanova.css" />
<link rel="stylesheet" href="/styles.css?v=2026052902" />
<script is:inline>
  // Lead form -> thrive-form-receiver (Render) -> Zoho REST + Resend + PostHog.
  // Reusing the /forms/hvac-form endpoint; landing_page=home distinguishes leads.
  window.thriveZohoForm = {
    receiverUrl: 'https://thrive-form-receiver.onrender.com/forms/hvac-form',
  };
</script>
<script is:inline src="/utm-capture.js" defer></script>
<script is:inline src="/analytics.js" defer></script>
<script is:inline src="/google-ads.js" defer></script>
<script is:inline>
  // BugHerd gated, only loads when ?bugherd=1 in URL OR cookie set
  (function () {
    var qs = new URLSearchParams(window.location.search);
    if (qs.get('bugherd') === '1') {
      try { document.cookie = 'thrive_bugherd=1; path=/; max-age=86400; samesite=lax'; } catch (e) {}
    }
    if (qs.get('bugherd') === '0') {
      try { document.cookie = 'thrive_bugherd=; path=/; max-age=0; samesite=lax'; } catch (e) {}
      return;
    }
    var enabled = qs.get('bugherd') === '1' || /(?:^|;\s*)thrive_bugherd=1/.test(document.cookie);
    if (!enabled) return;
    var s = document.createElement('script');
    s.src = 'https://www.bugherd.com/sidebarv2.js?apikey=r8parwkahxw0s0yhsj4weg';
    s.async = true;
    document.head.appendChild(s);
  })();
</script>
<script is:inline src="/fraud-blocker.js" defer></script>
<noscript><a href="https://fraudblocker.com" rel="nofollow"><img src="https://monitor.fraudblocker.com/fbt.gif?sid=XyA-dNMcQyzmox2s7K14D" alt="Fraud Blocker" /></a></noscript>
</head>
<body>

<!-- ============== 01 Sticky header ============== -->
<SiteHeader header={header} navItems={navItems} megaMenus={megaMenus} resultCards={resultCards} path="/" />

<!-- ============== 02 Hero, content left, form right ============== -->
<section class="hero hero-home">
  <div class="wrap">
    <div class="hero-grid">
      <div class="hero-left">
        <span class="urg-pill urg-pill-green"><span class="dot"></span>{home.hero_eyebrow}</span>
        <h1>{home.hero_heading_pre} <em>{home.hero_heading_em}</em></h1>
        <p class="hero-sub">{home.hero_sub}</p>
        <ul class="trust-list">
          {heroTrust.map((t) => (
            <li><span class="check"></span>{t}</li>
          ))}
        </ul>
        <div class="hero-team">
          <div class="hero-team-photos">
            <img src="/assets/Headshots/Ashton-Dobbs-1.png" alt="Ashton Dobbs, Senior Marketing Consultant" width="56" height="56" />
            <img src="/assets/Headshots/Kevin-Kluge.png" alt="Kevin Kluge, Senior Marketing Consultant" width="56" height="56" />
            <img src="/assets/Headshots/Sean.png" alt="Sean, Senior Marketing Consultant" width="56" height="56" />
            <img src="/assets/Headshots/Taylor-Rosthenhausler.png" alt="Taylor Rosthenhausler, Senior Marketing Consultant" width="56" height="56" />
          </div>
          <p class="hero-team-label">{home.hero_team_label}</p>
        </div>
      </div>

      <div class="hero-media">
        <div class="lead-form-card">
          <div class="lf-eyebrow"><span class="pulse"></span><span>{home.form_eyebrow}</span></div>
          <h2 class="lf-headline">{home.form_headline}</h2>
          <p class="lf-sub">{home.form_sub}</p>
          <form id="contactForm" class="contact-form" novalidate data-thrive-form>
            <input type="hidden" id="zc_gad" name="zc_gad" value="" />
            <input type="hidden" name="utm_source" value="">
            <input type="hidden" name="utm_medium" value="">
            <input type="hidden" name="utm_campaign" value="">
            <input type="hidden" name="utm_content" value="">
            <input type="hidden" name="utm_term" value="">
            <input type="hidden" name="gclid" value="">
            <input type="hidden" name="referrer" value="">
            <input type="hidden" name="landing_page" value="home">

            <div class="form-row">
              <label class="field">
                <span class="field-label">First Name <span class="req">*</span></span>
                <input name="first_name" type="text" required autocomplete="given-name" />
              </label>
              <label class="field">
                <span class="field-label">Last Name <span class="req">*</span></span>
                <input name="last_name" type="text" required autocomplete="family-name" />
              </label>
            </div>

            <div class="form-row">
              <label class="field">
                <span class="field-label">Company / Organization <span class="req">*</span></span>
                <input name="company" type="text" required autocomplete="organization" />
              </label>
              <label class="field">
                <span class="field-label">Website</span>
                <input name="website" type="url" autocomplete="url" placeholder="yourcompany.com" />
              </label>
            </div>

            <div class="form-row">
              <label class="field">
                <span class="field-label">Email <span class="req">*</span></span>
                <input name="email" type="email" required autocomplete="email" placeholder="you@company.com" />
              </label>
              <label class="field">
                <span class="field-label">Phone</span>
                <input name="phone" type="tel" autocomplete="tel" placeholder="(555) 555-5555" />
              </label>
            </div>

            <div class="form-row">
              <label class="field">
                <span class="field-label">Monthly Marketing Budget <span class="req">*</span></span>
                <!-- Values mirror Zoho CRM Lead.Monthly_Marketing_Budget picklist exactly so the lead-create call doesn't normalize. -->
                <select name="budget" required>
                  <option value="">Select…</option>
                  <option value="Under $750">Under $750</option>
                  <option value="$750 - $1,500">$750-$1,500</option>
                  <option value="$1,500-$3,000">$1,500-$3,000</option>
                  <option value="$3,000-$7,000">$3,000-$7,000</option>
                  <option value="$7,000 - $15,000">$7,000-$15,000</option>
                  <option value="$15,000 - $25,000">$15,000-$25,000</option>
                  <option value="$25,000 - $50,000">$25,000-$50,000</option>
                  <option value="$50,000 - $100,000">$50,000-$100,000</option>
                  <option value="Above $100,000">Above $100,000</option>
                </select>
              </label>
              <label class="field">
                <span class="field-label">Company Size <span class="req">*</span></span>
                <!-- Values mirror Zoho CRM Lead.Company_Size picklist. 200+ rolls up to "200-500+" since Zoho has no separate "+" bucket. -->
                <select name="company_size" required>
                  <option value="">Select…</option>
                  <option value="1-20">1 - 20</option>
                  <option value="20-50">20 - 50</option>
                  <option value="50-100">50 - 100</option>
                  <option value="100-200">100 - 200</option>
                  <option value="200-500+">200+</option>
                </select>
              </label>
            </div>

            <div class="form-actions">
              <button type="submit" class="btn btn-primary btn-block">{home.form_button}</button>
              <p class="form-fineprint">{home.form_fineprint}</p>
            </div>
          </form>

          <div class="lf-success" hidden>
            <div class="lf-success-check">✓</div>
            <h3>{home.form_success_heading}</h3>
            <p>{home.form_success_text}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============== 03 Trust strip ============== -->
<section class="trust-strip">
  <div class="wrap">
    <div class="ts-bar">
      <div class="ts-bar-item">
        <img class="ts-bar-logo" src="/assets/home/google-review-icon.svg" alt="Google" loading="lazy" />
        <div class="ts-bar-meta">
          <span class="ts-bar-num">{home.ts_google_num}</span>
          <span class="ts-bar-stars" aria-hidden="true">★★★★★</span>
          <span class="ts-bar-lab">Reviews</span>
        </div>
      </div>
      <div class="ts-bar-item">
        <img class="ts-bar-logo" src="/assets/home/clutch-reviewicon.svg" alt="Clutch" loading="lazy" />
        <div class="ts-bar-meta">
          <span class="ts-bar-num">{home.ts_clutch_num}</span>
          <span class="ts-bar-stars" aria-hidden="true">★★★★★</span>
          <span class="ts-bar-lab">Reviews</span>
        </div>
      </div>
      <div class="ts-bar-item ts-bar-item-reviews">
        <img class="ts-bar-faces" src="/assets/home/client-reviewgreen-bar.png" alt="Six client portraits" loading="lazy" />
        <div class="ts-bar-meta ts-bar-meta-stack">
          <a class="ts-bar-link" href={home.ts_reviews_url} target="_blank" rel="noopener">
            {home.ts_reviews_text}
            <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M9 7h8v8"/></svg>
          </a>
          <span class="ts-bar-stars ts-bar-stars-lg" aria-hidden="true">★★★★★</span>
        </div>
      </div>
    </div>
    <div class="ts-logo-marquee" aria-label="Accreditations and partner badges">
      <div class="ts-marquee-track">
        <ul class="ts-marquee-row" aria-hidden="false">
          <li><img src="/assets/Logos/Featured%207x.png" alt="Inc. 5000 Featured 7x" loading="lazy" /></li>
          <li><img src="/assets/Logos/Microsoft%20Partner.png" alt="Microsoft Advertising Partner 2026" loading="lazy" /></li>
          <li><img src="/assets/Logos/Meta%20Business%20Partner.png" alt="Meta Business Partner" loading="lazy" /></li>
          <li><img src="/assets/Logos/IFA.png" alt="International Franchise Association Member" loading="lazy" /></li>
          <li><img src="/assets/Logos/Shopify%20Partner.png" alt="Shopify Partner" loading="lazy" /></li>
        </ul>
        <ul class="ts-marquee-row" aria-hidden="true">
          <li><img src="/assets/Logos/Featured%207x.png" alt="" loading="lazy" /></li>
          <li><img src="/assets/Logos/Microsoft%20Partner.png" alt="" loading="lazy" /></li>
          <li><img src="/assets/Logos/Meta%20Business%20Partner.png" alt="" loading="lazy" /></li>
          <li><img src="/assets/Logos/IFA.png" alt="" loading="lazy" /></li>
          <li><img src="/assets/Logos/Shopify%20Partner.png" alt="" loading="lazy" /></li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- ============== 03.5 Awards and recognition strip ============== -->
<section class="awards-section">
  <div class="wrap">
    <span class="awards-eyebrow">{home.awards_eyebrow}</span>
    <div class="awards-strip">
      <img class="awards-desktop" src="/assets/Logo%20Strip.webp" alt="Industry accreditations: Google Partner Premier, Clutch, Forbes Agency Council, Top 10 Agency, Most Reviewed Digital Agencies, Gold Telly Award winner, The Manifest Top SEO Provider, Best Local SEO Top 10" />
      <img class="awards-mobile" src="/assets/Logo%20Strip.webp" alt="Industry accreditations: Google Partner Premier, Clutch, Forbes Agency Council, Top 10 Agency, Most Reviewed Digital Agencies, Gold Telly Award winner, The Manifest Top SEO Provider, Best Local SEO Top 10" />
    </div>
  </div>
</section>

<!-- ============== 04 Client result videos ============== -->
<section class="results-videos" id="results">
  <div class="wrap">
    <h2 class="section-h2">{home.results_h2}</h2>
    <p class="section-sub">{home.results_sub}</p>

    <div class="rv-grid">
      {results.map((r) => (
        <article class="rv-card">
          <a class="rv-thumb" href={r.video_url} target="_blank" rel="noopener" aria-label={`Watch the ${r.attrib} case study on YouTube`}>
            <img src={`https://img.youtube.com/vi/${r.video_id}/maxresdefault.jpg`} alt={`${r.attrib} case study video thumbnail`} loading="lazy" />
          </a>
          <div class="rv-body">
            <p class="rv-quote"><em>{r.quote}</em></p>
            <p class="rv-attrib">{r.attrib}</p>
            <div class="rv-stats-wrap">
              <span class="rv-stats-seal">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" width="11" height="11" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                Verified Result
              </span>
              <ul class="rv-stats">
                <li><strong class="rv-stat-num">{r.stat1_num}</strong><span class="rv-stat-lab">{r.stat1_lab}</span></li>
                <li><strong class="rv-stat-num">{r.stat2_num}</strong><span class="rv-stat-lab">{r.stat2_lab}</span></li>
                <li><strong class="rv-stat-num">{r.stat3_num}</strong><span class="rv-stat-lab">{r.stat3_lab}</span></li>
              </ul>
            </div>
            <a class="rv-link" href={r.link_url} target="_blank" rel="noopener">{r.link_text}</a>
          </div>
        </article>
      ))}
    </div>

    <div class="rv-cta">
      <a class="btn btn-primary" href={home.results_cta_url} target="_blank" rel="noopener">{home.results_cta_text}</a>
    </div>
  </div>
</section>

<!-- ============== 05 More Client Wins (6-card mini-strip) ============== -->
<section class="wins-strip">
  <div class="wrap">
    <h2 class="section-h2">{home.wins_h2}</h2>
    <p class="section-sub">{home.wins_sub}</p>

    <div class="wins-grid">
      {wins.map((w) => (
        <article class="win-card">
          <div class="win-head">
            <span class="win-pill">{w.pill}</span>
            <div class="win-logo">
              <img src={w.logo} alt={w.pill} />
            </div>
          </div>
          <div class="win-hero">
            <span class="win-hero-num">{w.hero_num}</span>
            <span class="win-hero-lab">{w.hero_lab}</span>
          </div>
          <ul class="win-stats">
            <li><strong>{w.stat1.split('|')[0]}</strong> {w.stat1.split('|')[1]}</li>
            <li><strong>{w.stat2.split('|')[0]}</strong> {w.stat2.split('|')[1]}</li>
          </ul>
          <div class="win-foot">
            <p class="win-services">{w.services}</p>
            <a class="win-link" href={w.link_url} target="_blank" rel="noopener">{w.link_text}</a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- ============== 06 Inc 5000 callout ============== -->
<section class="inc5000-callout">
  <div class="wrap">
    <h2 class="inc-headline">{home.inc_headline}</h2>

    <div class="inc-card">
      <div class="inc-card-badge">
        <img src="/assets/badge-inc-5000.webp" alt="Featured 7x on the Inc. 5000 list" width="320" height="220" />
      </div>
      <div class="inc-card-body" set:html={home.inc_body_html}></div>
    </div>

    <div class="inc-cta">
      <a class="btn btn-primary" href={home.inc_cta_url}>{home.inc_cta_text}</a>
    </div>
  </div>
</section>

<!-- ============== 06.5 Positioning + testimonial carousel ============== -->
<section class="voices">
  <div class="wrap">
    <div class="voices-grid">
      <div class="voices-copy">
        <h2 class="section-h2 section-h2-left">{home.voices_h2}</h2>
        <Fragment set:html={home.voices_body_html} />
        <a class="btn btn-primary" href={home.voices_cta_url}>{home.voices_cta_text}</a>
      </div>
      <div class="voices-media">
        <div class="testimonial-carousel" data-tc>
          <div class="tc-stage" role="region" aria-roledescription="carousel" aria-label="Client testimonials">
            {testimonials.map((t, i) => (
              <img class:list={['tc-slide', i === 0 ? 'is-active' : '']} src={t.image} alt={t.alt} loading="lazy" />
            ))}
          </div>
          <div class="tc-dots" role="tablist" aria-label="Choose testimonial">
            {testimonials.map((t, i) => (
              <button class:list={['tc-dot', i === 0 ? 'is-active' : '']} type="button" role="tab" aria-selected={i === 0 ? 'true' : 'false'} aria-label={`Show testimonial ${i + 1} of ${testimonials.length}`}></button>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============== 06.6 Best AI SEO Agency for AI Visibility ============== -->
<section class="ai-visibility" id="ai-visibility">
  <div class="wrap">
    <div class="aiv-head">
      <h2 class="aiv-h2">{home.aiv_h2_pre} <span class="aiv-rainbow">{home.aiv_h2_em}</span></h2>
      <p class="aiv-sub">{home.aiv_sub}</p>
    </div>

    <div class="aiv-stats">
      <div class="aiv-stat aiv-stat-blue">
        <div class="aiv-stat-num">{home.aiv_stat1_num}</div>
        <div class="aiv-stat-label">{home.aiv_stat1_lab}</div>
      </div>
      <div class="aiv-stat aiv-stat-teal">
        <div class="aiv-stat-num">{home.aiv_stat2_num}</div>
        <div class="aiv-stat-label">{home.aiv_stat2_lab}</div>
      </div>
      <div class="aiv-stat aiv-stat-green">
        <div class="aiv-stat-num">{home.aiv_stat3_num}</div>
        <div class="aiv-stat-label">{home.aiv_stat3_lab}</div>
      </div>
    </div>

    <div class="aiv-body">
      <div class="aiv-copy" set:html={home.aiv_body_html}></div>

      <div class="aiv-deck" data-aiv-deck>
        <div class="aiv-tabs" role="tablist" aria-label="AI visibility services">
          <button class="aiv-tab is-active" type="button" role="tab" aria-selected="true" data-aiv-index="0" aria-label="AI Mode Visibility">
            <svg viewBox="0 0 50 50" fill="currentColor" aria-hidden="true"><path d="M 25 12 C 11.667969 12 1.25 24.34375 1.25 24.34375 C 0.921875 24.71875 0.921875 25.28125 1.25 25.65625 C 1.25 25.65625 11.667969 38 25 38 C 38.332031 38 48.75 25.65625 48.75 25.65625 C 49.078125 25.28125 49.078125 24.71875 48.75 24.34375 C 48.75 24.34375 38.332031 12 25 12 Z M 25 14 C 27.628906 14 30.140625 14.542969 32.46875 15.375 C 34.03125 17.140625 35 19.449219 35 22 C 35 27.535156 30.535156 32 25 32 C 19.464844 32 15 27.535156 15 22 C 15 19.449219 15.9375 17.140625 17.5 15.375 C 19.835938 14.539063 22.363281 14 25 14 Z M 14.1875 16.84375 C 13.4375 18.40625 13 20.15625 13 22 C 13 28.617188 18.382813 34 25 34 C 31.617188 34 37 28.617188 37 22 C 37 20.164063 36.582031 18.40625 35.84375 16.84375 C 41.492188 19.714844 45.554688 23.878906 46.59375 25 C 44.96875 26.757813 35.972656 36 25 36 C 14.027344 36 5.03125 26.757813 3.40625 25 C 4.445313 23.875 8.527344 19.714844 14.1875 16.84375 Z M 25 17 C 22.238281 17 20 19.238281 20 22 C 20 24.761719 22.238281 27 25 27 C 27.761719 27 30 24.761719 30 22 C 30 19.238281 27.761719 17 25 17 Z"/></svg>
          </button>
          <button class="aiv-tab" type="button" role="tab" aria-selected="false" data-aiv-index="1" aria-label="AI Overviews Visibility">
