---
export const prerender = false; // Live SSR — Directus edits reflect on refresh

import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import {
  getDMS, getDmsCases, getDmsTestimonials, getDmsTools, getDmsServices, getDmsReasons, getDmsFaqs,
} from '../lib/directus';

const [dms, cases, testimonials, tools, services, reasons, faqs] = await Promise.all([
  getDMS(), getDmsCases(), getDmsTestimonials(), getDmsTools(), getDmsServices(), getDmsReasons(), getDmsFaqs(),
]);

// Split CMS multiline fields into paragraphs / bullet lists
const paras = (s: string) => (s || '').split(/\n{2,}/).map((p) => p.trim()).filter(Boolean);
const lines = (s: string) => (s || '').split(/\n+/).map((l) => l.trim()).filter(Boolean);
const introParas = paras(dms.intro_body);
const impactParas = paras(dms.impact_body);
const whyuseParas = paras(dms.whyuse_body);
const whychooseParas = paras(dms.whychoose_body);
const howList = lines(dms.how_list);
const whyuseList = lines(dms.whyuse_list);
const ranks = [
  { label: dms.how_rank1, img: '/assets/dms/digital-marketing-googlesearch.png' },
  { label: dms.how_rank2, img: '/assets/dms/marketing-agency-googlemap.png' },
  { label: dms.how_rank3, img: '/assets/dms/digital-makreting-chatgptearch.png' },
];

const BTN = 'inline-flex items-center justify-center rounded-full bg-[#db7803] hover:bg-[#c26a00] transition-colors text-white font-extrabold uppercase tracking-wide text-[13px] px-7 py-3.5';
const BTN_GHOST = 'inline-flex items-center justify-center rounded-full border-2 border-[#7ab317] text-[#5f8f12] hover:bg-[#7ab317] hover:text-white transition-colors font-extrabold uppercase tracking-wide text-[13px] px-7 py-3.5';
---

<Layout title={dms.seo_title || 'Digital Marketing Services | Thrive'} description={dms.seo_description}>
  <!-- ============== Hero ============== -->
  <section class="relative overflow-hidden bg-gradient-to-b from-[#eef5e0] via-[#f6faf0] to-white">
    <div class="pointer-events-none absolute -left-24 top-0 h-72 w-72 rounded-full bg-[#cfe39b]/40 blur-3xl"></div>
    <div class="pointer-events-none absolute -right-24 bottom-0 h-72 w-72 rounded-full bg-[#cfe39b]/40 blur-3xl"></div>
    <div class="relative max-w-3xl mx-auto px-4 py-20 text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold text-[#333] tracking-tight">{dms.hero_h1}</h1>
      <p class="mt-4 text-lg md:text-xl text-[#5f8f12] font-medium">{dms.hero_sub}</p>
      <form action="/" method="get" class="mt-8 mx-auto max-w-xl rounded-2xl bg-white/70 p-3 shadow-sm flex flex-col sm:flex-row gap-3">
        <div class="relative flex-1">
          <img src="/assets/menu/services/email-globe-icon.png" alt="" width="18" height="18" class="absolute left-3.5 top-1/2 -translate-y-1/2 w-[18px] h-[18px] opacity-70 pointer-events-none" />
          <input name="website" type="text" autocomplete="off" aria-label="Website address" placeholder="Enter Website Address"
            class="w-full h-[52px] rounded-xl border border-[#ddd] bg-white pl-10 pr-3 text-[15px] text-[#555] focus:outline-none focus:ring-2 focus:ring-[#7ab317]/50" />
        </div>
        <button type="submit" class={BTN + ' h-[52px] shrink-0'}>{dms.hero_form_button}</button>
      </form>
    </div>
    <div class="relative bg-[#f3f8ea] border-t border-[#e3eecb]">
      <div class="max-w-7xl mx-auto px-4 py-3 text-center text-sm text-[#6b7280]">
        <a href="/" class="hover:text-[#7ab317]">Home</a> <span class="mx-1">/</span> <span class="text-[#5f8f12] font-semibold">{dms.hero_h1}</span>
      </div>
    </div>
  </section>

  <!-- ============== Intro ============== -->
  <section class="max-w-7xl mx-auto px-4 py-20">
    <h2 class="text-center text-3xl md:text-[34px] font-extrabold text-[#333] max-w-3xl mx-auto">{dms.intro_h2}</h2>
    <div class="mt-12 grid lg:grid-cols-2 gap-12 items-center">
      <div class="space-y-4 text-[#555] text-[15px] leading-relaxed">
        {introParas.map((p) => <p>{p}</p>)}
        <a href={dms.intro_cta_url} class={BTN + ' mt-2'}>{dms.intro_cta_text}</a>
      </div>
      <a href={dms.testi_cta_url} class="relative block rounded-2xl overflow-hidden shadow-lg group">
        <img src={dms.intro_video_image} alt="Thrive client testimonial" class="block w-full h-auto" loading="lazy" />
        <span class="absolute inset-0 flex items-center justify-center">
          <span class="w-16 h-16 rounded-full bg-white/90 group-hover:bg-white flex items-center justify-center shadow-lg transition-colors">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="#db7803" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
          </span>
        </span>
      </a>
    </div>
  </section>

  <!-- ============== Reviews strip ============== -->
  <section class="bg-[#403C33] text-white">
    <div class="max-w-5xl mx-auto px-4 py-10 flex flex-wrap items-center justify-center gap-x-14 gap-y-6 text-center">
      <div>
        <div class="text-4xl font-extrabold">{dms.reviews_g_num}</div>
        <div class="text-sm text-white/80">{dms.reviews_g_label}</div>
      </div>
      <img src="/assets/dms/largestarreviews.svg" alt="5 star reviews" class="h-8 w-auto" loading="lazy" />
      <div>
        <div class="text-4xl font-extrabold">{dms.reviews_c_num}</div>
        <div class="text-sm text-white/80">{dms.reviews_c_label}</div>
      </div>
      <div class="text-[#a9c764] font-bold text-lg">{dms.reviews_note}</div>
    </div>
  </section>

  <!-- ============== The Thrive Impact (case studies) ============== -->
  <section class="bg-[#f8faf3] py-20">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-[34px] font-extrabold text-[#333]">{dms.impact_h2}</h2>
        <p class="mt-3 text-[#7ab317] font-bold text-lg">{dms.impact_sub}</p>
        <div class="mt-4 space-y-3 text-[#555] text-[15px]">{impactParas.map((p) => <p>{p}</p>)}</div>
      </div>
      <div class="mt-12 grid md:grid-cols-3 gap-6">
        {cases.map((c) => (
          <article class="bg-white rounded-2xl overflow-hidden shadow-sm border border-slate-100 flex flex-col">
            <img src={c.image} alt={c.name} class="block w-full aspect-[16/9] object-cover" loading="lazy" />
            <div class="p-6 flex flex-col flex-1">
              <h3 class="text-sm font-extrabold uppercase tracking-wide text-[#333]">{c.name}</h3>
              <div class="mt-4 flex gap-6">
                <div><div class="text-2xl font-extrabold text-[#7ab317]">{c.stat1_num}</div><div class="text-xs text-[#777]">{c.stat1_label}</div></div>
                <div><div class="text-2xl font-extrabold text-[#7ab317]">{c.stat2_num}</div><div class="text-xs text-[#777]">{c.stat2_label}</div></div>
              </div>
              <p class="mt-4 text-[13px] leading-relaxed text-[#666] flex-1">{c.description}</p>
            </div>
          </article>
        ))}
      </div>
      <div class="mt-10 text-center"><a href={dms.impact_cta_url} class={BTN}>{dms.impact_cta_text}</a></div>
    </div>
  </section>

  <!-- ============== How it drives growth ============== -->
  <section class="max-w-7xl mx-auto px-4 py-20">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-3xl md:text-[34px] font-extrabold text-[#333]">{dms.how_h2}</h2>
        <p class="mt-3 text-[#7ab317] font-bold text-lg">{dms.how_sub}</p>
        <p class="mt-4 text-[#555] text-[15px]">{dms.how_body}</p>
        <ul class="mt-4 space-y-2">
          {howList.map((l) => (
            <li class="flex gap-2 text-[#555] text-[15px]"><span class="text-[#7ab317] font-bold">✓</span><span>{l}</span></li>
          ))}
        </ul>
        <p class="mt-4 text-[#555] text-[15px]">{dms.how_body2}</p>
      </div>
      <img src={dms.how_image} alt="Business growth" class="rounded-2xl shadow-md w-full h-auto" loading="lazy" />
    </div>
    <div class="mt-12 grid sm:grid-cols-3 gap-6">
      {ranks.map((r) => (
        <div class="rounded-2xl border border-slate-100 shadow-sm bg-white overflow-hidden">
          <img src={r.img} alt={r.label} class="block w-full h-44 object-cover object-top" loading="lazy" />
          <div class="p-4 text-center font-extrabold text-[#333]">{r.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ============== Testimonials ============== -->
  <section class="bg-[#f8faf3] py-20">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center">
        <h2 class="text-3xl md:text-[34px] font-extrabold text-[#333]">{dms.testi_h3}</h2>
        <p class="mt-3 text-[#7ab317] font-bold text-lg">{dms.testi_sub}</p>
      </div>
      <div class="mt-12 grid md:grid-cols-3 gap-6">
        {testimonials.map((t) => (
          <figure class="bg-white rounded-2xl p-7 shadow-sm border border-slate-100 flex flex-col">
            <img src="/assets/dms/starreview-icons.svg" alt="5 stars" class="h-5 w-auto mb-4" loading="lazy" />
            <h3 class="font-extrabold text-[#333] text-[17px] leading-snug">“{t.headline}”</h3>
            <blockquote class="mt-3 text-[13px] leading-relaxed text-[#666] flex-1">{t.quote}</blockquote>
            <figcaption class="mt-4 font-bold text-[#7ab317] text-sm">— {t.author}</figcaption>
          </figure>
        ))}
      </div>
      <div class="mt-10 text-center"><a href={dms.testi_cta_url} class={BTN_GHOST}>{dms.testi_cta_text}</a></div>
    </div>
  </section>

  <!-- ============== Proprietary tools ============== -->
  <section class="max-w-7xl mx-auto px-4 py-20">
    <div class="text-center max-w-3xl mx-auto">
      <h2 class="text-3xl md:text-[34px] font-extrabold text-[#333]">{dms.tools_h2}</h2>
      <p class="mt-3 text-[#7ab317] font-bold text-lg">{dms.tools_sub}</p>
      <p class="mt-4 text-[#555] text-[15px]">{dms.tools_body}</p>
    </div>
    <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {tools.map((t) => (
        <div class="rounded-2xl border border-slate-100 shadow-sm p-6 text-center hover:shadow-md transition-shadow">
          <img src={t.image} alt={t.title} class="h-14 w-auto mx-auto" loading="lazy" />
          <h3 class="mt-4 font-extrabold text-[#333]">{t.title}</h3>
          <p class="mt-2 text-[13px] leading-relaxed text-[#666]">{t.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ============== Services grid ============== -->
  <section class="bg-[#f8faf3] py-20">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-[34px] font-extrabold text-[#333]">{dms.services_h2}</h2>
        <p class="mt-3 text-[#7ab317] font-bold text-lg">{dms.services_sub}</p>
      </div>
      <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((s) => (
          <a href={s.url} class="group bg-white rounded-2xl border border-slate-100 shadow-sm p-6 hover:shadow-md hover:-translate-y-0.5 transition-all">
            <div class="flex items-center gap-3">
              <img src={s.image} alt="" width="28" height="28" class="w-7 h-7 object-contain shrink-0" loading="lazy" />
              <h3 class="font-extrabold text-[#333] text-[15px] leading-tight group-hover:text-[#7ab317] transition-colors">{s.title}</h3>
            </div>
            <p class="mt-3 text-[13px] leading-relaxed text-[#666]">{s.description}</p>
          </a>
        ))}
      </div>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a href={dms.services_cta_url} class={BTN}>{dms.services_cta_text}</a>
        <a href={dms.services_cta2_url} class={BTN_GHOST}>{dms.services_cta2_text}</a>
      </div>
    </div>
  </section>

  <!-- ============== Why your business should use DMS ============== -->
  <section class="max-w-7xl mx-auto px-4 py-20">
    <div class="text-center max-w-3xl mx-auto">
      <h2 class="text-3xl md:text-[34px] font-extrabold text-[#333]">{dms.whyuse_h2}</h2>
      <p class="mt-3 text-[#7ab317] font-bold text-lg">{dms.whyuse_sub}</p>
    </div>
    <div class="mt-8 max-w-4xl mx-auto space-y-4 text-[#555] text-[15px]">
      {whyuseParas.map((p) => <p>{p}</p>)}
      <ul class="grid sm:grid-cols-2 gap-x-8 gap-y-2 pt-2">
        {whyuseList.map((l) => (
          <li class="flex gap-2"><span class="text-[#7ab317] font-bold">✓</span><span>{l}</span></li>
        ))}
      </ul>
      <p>{dms.whyuse_body2}</p>
      <div class="pt-2"><a href={dms.whyuse_cta_url} class={BTN}>{dms.whyuse_cta_text}</a></div>
    </div>
  </section>

  <!-- ============== Why choose Thrive ============== -->
  <section class="bg-[#f8faf3] py-20">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-[34px] font-extrabold text-[#333]">{dms.whychoose_h2}</h2>
        <p class="mt-3 text-[#7ab317] font-bold text-lg">{dms.whychoose_sub}</p>
        <div class="mt-4 space-y-3 text-[#555] text-[15px]">{whychooseParas.map((p) => <p>{p}</p>)}</div>
      </div>
      <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {reasons.map((r) => (
          <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6">
            <span class="w-12 h-12 rounded-xl bg-[#eef4e0] flex items-center justify-center">
              <Icon name={'lucide:' + (r.icon || 'check')} class="w-6 h-6 text-[#7ab317]" />
            </span>
            <h3 class="mt-4 font-extrabold text-[#333]">{r.title}</h3>
            <p class="mt-2 text-[13px] leading-relaxed text-[#666]">{r.description}</p>
          </div>
        ))}
      </div>
      <div class="mt-10 text-center"><a href={dms.whychoose_cta_url} class={BTN}>{dms.whychoose_cta_text}</a></div>
    </div>
  </section>

  <!-- ============== FAQs ============== -->
  <section class="max-w-3xl mx-auto px-4 py-20">
    <h2 class="text-center text-3xl md:text-[34px] font-extrabold text-[#333]">{dms.faqs_h2}</h2>
    <div class="mt-10 divide-y divide-slate-200 border-y border-slate-200">
      {faqs.map((f) => (
        <details class="group py-4">
          <summary class="flex cursor-pointer items-center justify-between gap-4 font-extrabold text-[#333] text-[15px] list-none">
            <span>{f.question}</span>
            <span class="text-[#7ab317] text-xl transition-transform group-open:rotate-45 shrink-0">+</span>
          </summary>
          <p class="mt-3 text-[14px] leading-relaxed text-[#666]">{f.answer}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- ============== Closing CTA ============== -->
  <section class="max-w-7xl mx-auto px-4 pb-20">
    <div class="rounded-3xl bg-gradient-to-br from-[#86a93c] to-[#6f9230] text-white px-8 py-14 md:px-16 text-center">
      <h2 class="text-3xl md:text-4xl font-extrabold">{dms.cta_h2}</h2>
      <p class="mt-4 max-w-2xl mx-auto text-white/90 text-[15px] leading-relaxed">{dms.cta_text}</p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a href={dms.cta_btn1_url} class={BTN}>{dms.cta_btn1_text}</a>
        <a href="tel:8883420534" class="inline-flex items-center justify-center rounded-full border-2 border-white text-white hover:bg-white hover:text-[#5f8f12] transition-colors font-extrabold uppercase tracking-wide text-[13px] px-7 py-3.5">{dms.cta_btn2_text}</a>
      </div>
    </div>
  </section>
</Layout>
