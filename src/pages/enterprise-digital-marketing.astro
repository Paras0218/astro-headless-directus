---
export const prerender = false; // Live SSR — Directus edits reflect on refresh

import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { getEnterprise } from '../lib/directus';

const e = await getEnterprise();

// Parsing helpers (same convention as the dms-strategy page).
const lines = (s: string) => (s || '').split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
const paras = (s: string) => (s || '').split(/\n{2,}/).map((p) => p.trim()).filter(Boolean);
const rows = (s: string) => lines(s).map((l) => l.split('|').map((c) => c.trim()));

const why = rows(e.why_items);                       // [title, desc]
const cases = rows(e.cases_items);                   // [name, s1n, s1l, s2n, s2l, quote]
const blocks = lines(e.services_blocks).map((l) => l.split('||').map((c) => c.trim())); // [title, intro]
const subs = rows(e.services_subitems);              // [blockNum, title, desc]
const subsByBlock: Record<string, [string, string][]> = {};
subs.forEach(([n, title, desc]) => { (subsByBlock[n] ||= []).push([title, desc]); });
const includedItems = rows(e.included_s1_items);     // [title, desc]
const s2list = lines(e.included_s2_list);
const s3list = lines(e.included_s3_list);
const whychoose = rows(e.whychoose_items);           // [title, desc]
const faqs = rows(e.faqs_items);                     // [q, a]

// Lucide icons mapped by index (no proprietary SVGs needed; green like the theme).
const whyIcons = ['trending-up', 'database', 'globe', 'user-plus', 'badge-check', 'crosshair'];
const whychooseIcons = ['sliders-horizontal', 'workflow', 'activity', 'bar-chart-3', 'layout-grid', 'palette'];
const serviceIcons = ['search', 'monitor', 'share-2', 'megaphone', 'file-text', 'shopping-cart', 'map-pin', 'line-chart'];
const subIcons = ['map-pin', 'wrench', 'link', 'star', 'sliders-horizontal', 'layout-template', 'shopping-bag', 'server', 'badge-check', 'video', 'building-2', 'phone'];
const whyTints = ['bg-[#eef5e0]', 'bg-[#e7f1f5]', 'bg-[#fdeee0]', 'bg-[#f1ecf6]', 'bg-[#eaf3ec]', 'bg-[#fbf3d8]'];
const includedTints = ['bg-[#eef5e0]', 'bg-[#e7f1f5]', 'bg-[#fdeee0]'];

const BTN = 'inline-flex items-center justify-center rounded-full bg-[#db7803] hover:bg-[#c26a00] transition-colors text-white font-extrabold uppercase tracking-wide text-[13px] px-7 py-3.5';
const BTN_OUTLINE = 'inline-flex items-center justify-center rounded-full border-2 border-[#7ab317] text-[#5f8f12] hover:bg-[#f3f8ea] transition-colors font-extrabold uppercase tracking-wide text-[13px] px-7 py-3.5';
---

<Layout title={e.seo_title || 'Enterprise Digital Marketing Services | Thrive'} description={e.seo_description}>
  <!-- ============== Hero ============== -->
  <section class="relative overflow-hidden bg-white">
    <div aria-hidden="true" class="pointer-events-none absolute left-0 top-0 bottom-0 w-[30%] max-w-[460px]" style="background:url(/assets/dms-strategy/subpage-header-left-corner.svg) no-repeat left bottom; background-size:contain;"></div>
    <div aria-hidden="true" class="pointer-events-none absolute right-0 top-0 bottom-0 w-[30%] max-w-[460px]" style="background:url(/assets/dms-strategy/subpage-header-right-corner.svg) no-repeat right bottom; background-size:contain;"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-4 py-20 text-center">
      <h1 class="text-4xl md:text-[52px] leading-[1.08] font-extrabold text-[#333] tracking-tight">{e.hero_h1}</h1>
      <p class="mt-4 text-lg md:text-xl text-[#5f8f12] font-semibold">{e.hero_sub}</p>
      <form action="/" method="get" class="mt-9 mx-auto max-w-2xl rounded-2xl bg-white/80 p-3 shadow-sm flex flex-col sm:flex-row gap-3">
        <div class="relative flex-1">
          <img src="/assets/menu/services/email-globe-icon.png" alt="" width="18" height="18" class="absolute left-3.5 top-1/2 -translate-y-1/2 w-[18px] h-[18px] opacity-70 pointer-events-none" />
          <input name="website" type="text" autocomplete="off" aria-label="Website address" placeholder="Enter Website Address"
            class="w-full h-[52px] rounded-xl border border-[#ddd] bg-white pl-10 pr-3 text-[15px] text-[#555] focus:outline-none focus:ring-2 focus:ring-[#7ab317]/50" />
        </div>
        <button type="submit" class={BTN + ' h-[52px] shrink-0'}>{e.hero_form_button || 'GET MY FREE PROPOSAL'}</button>
      </form>
    </div>
    <div class="relative bg-[#f3f8ea] border-y border-[#e3eecb]">
      <div class="max-w-7xl mx-auto px-4 py-3 text-center text-sm text-[#6b7280]">
        <a href="/" class="hover:text-[#7ab317]">⌂ Home</a> <span class="mx-1">/</span>
        <a href="/digital-marketing-services" class="hover:text-[#7ab317]">Digital Marketing Services</a> <span class="mx-1">/</span>
        <span class="text-[#5f8f12] font-semibold">Enterprise Digital Marketing</span>
      </div>
    </div>
  </section>

  <!-- ============== Intro — Engage & Convert ============== -->
  <section class="max-w-[1170px] mx-auto px-5 pt-16 pb-10">
    <div class="grid lg:grid-cols-2 gap-10 items-center">
      <div>
        <h2 class="text-[26px] md:text-[32px] font-extrabold text-[#333] leading-tight mb-4">{e.intro_h2}</h2>
        <div class="space-y-3 text-[#49453b] text-[16px] leading-relaxed">
          {paras(e.intro_body).map((p) => <p>{p}</p>)}
        </div>
      </div>
      <div class="rounded-3xl bg-[#f3f8ea] border border-[#e3eecb] p-8 md:p-10">
        <h3 class="text-xl font-extrabold text-[#5f8f12] mb-3">{e.intro_sub_h}</h3>
        <div class="space-y-3 text-[#49453b] text-[15px] leading-relaxed">
          {paras(e.intro_body2).map((p) => <p>{p}</p>)}
        </div>
        {e.intro_cta_text && (
          <div class="mt-7"><a href={e.intro_cta_url || '/'} class={BTN}>{e.intro_cta_text}</a></div>
        )}
      </div>
    </div>
  </section>

  <!-- ============== Reviews trust strip ============== -->
  <section class="border-y border-[#e3eecb] bg-[#f3f8ea]">
    <div class="max-w-7xl mx-auto px-4 py-5 flex flex-wrap items-center justify-center gap-x-10 gap-y-4">
      <div class="flex items-center gap-2"><img src="/assets/home/google-review-icon.svg" alt="Google" class="h-7 w-auto" loading="lazy" /><span class="font-extrabold text-[#333]">150+</span><span class="text-[#f5a623]">★★★★★</span><span class="text-sm text-[#6b7280]">Reviews</span></div>
      <div class="flex items-center gap-2"><img src="/assets/home/clutch-reviewicon.svg" alt="Clutch" class="h-7 w-auto" loading="lazy" /><span class="font-extrabold text-[#333]">100+</span><span class="text-[#f5a623]">★★★★★</span><span class="text-sm text-[#6b7280]">Reviews</span></div>
      <div class="flex items-center gap-3"><span class="text-sm font-bold text-[#5f8f12]">Over 1,000 Client Reviews</span></div>
    </div>
  </section>

  <!-- ============== Why your business needs it (6 cards) ============== -->
  <section class="max-w-7xl mx-auto px-4 py-20">
    <div class="text-center max-w-3xl mx-auto">
      <p class="text-[#7ab317] font-bold text-lg">{e.why_eyebrow}</p>
      <h2 class="mt-2 text-3xl md:text-[34px] font-extrabold text-[#333]">{e.why_h2}</h2>
      <p class="mt-4 text-[#555] text-[15px]">{e.why_body}</p>
    </div>
    <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {why.map(([title, desc], i) => (
        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-7 hover:shadow-md transition-shadow">
          <div class="w-14 h-14 rounded-2xl bg-[#f3f8ea] flex items-center justify-center">
            <Icon name={'lucide:' + whyIcons[i % whyIcons.length]} class="w-7 h-7 text-[#7ab317]" />
          </div>
          <h3 class="mt-4 font-extrabold text-[#333] text-[17px]">{title}</h3>
          <p class="mt-2 text-[14px] leading-relaxed text-[#666]">{desc}</p>
        </div>
      ))}
    </div>
    {e.why_cta_text && (
      <div class="mt-12 text-center"><a href={e.why_cta_url || '/'} class={BTN}>{e.why_cta_text}</a></div>
    )}
  </section>

  <!-- ============== Case studies ============== -->
  <section class="bg-[#f8faf3] py-20">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto">
        <p class="text-[#7ab317] font-bold text-lg">{e.cases_eyebrow}</p>
        <h2 class="mt-2 text-3xl md:text-[34px] font-extrabold text-[#333]">{e.cases_h2}</h2>
        <p class="mt-4 text-[#555] text-[15px]">{e.cases_body}</p>
      </div>
      <div class="mt-12 grid md:grid-cols-3 gap-6">
        {cases.map(([name, s1n, s1l, s2n, s2l, quote]) => (
          <div class="rounded-3xl bg-[#403C33] text-white p-7 flex flex-col">
            <h3 class="text-[#a9c764] font-extrabold uppercase tracking-wide text-[13px] leading-snug min-h-[40px]">{name}</h3>
            <div class="mt-5 grid grid-cols-2 gap-4 text-center">
              <div><div class="text-3xl font-extrabold text-[#a9c764]">{s1n}</div><div class="mt-1 text-xs text-white/75">{s1l}</div></div>
              <div><div class="text-3xl font-extrabold text-[#a9c764]">{s2n}</div><div class="mt-1 text-xs text-white/75">{s2l}</div></div>
            </div>
            <p class="mt-5 text-[13px] leading-relaxed text-white/85"><span class="text-[#a9c764] font-bold">From the client: </span>{quote}</p>
          </div>
        ))}
      </div>
      {e.cases_footer && <p class="mt-10 text-center text-[#555] text-[15px] max-w-3xl mx-auto">{e.cases_footer}</p>}
      {e.cases_cta_text && (
        <div class="mt-8 text-center"><a href={e.cases_cta_url || '/'} class={BTN}>{e.cases_cta_text}</a></div>
      )}
    </div>
  </section>

  <!-- ============== Enterprise services (numbered blocks + sub-items) ============== -->
  <section class="max-w-7xl mx-auto px-4 py-20">
    <div class="text-center max-w-3xl mx-auto">
      <p class="text-[#7ab317] font-bold text-lg">{e.services_eyebrow}</p>
      <h2 class="mt-2 text-3xl md:text-[34px] font-extrabold text-[#333]">{e.services_h2}</h2>
    </div>
    <div class="mt-12 space-y-8">
      {blocks.map(([title, intro], i) => {
        const items = subsByBlock[String(i + 1)] || [];
        return (
          <div class="rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
            <div class="bg-[#f3f8ea] border-b border-[#e3eecb] px-7 py-6 flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-[#7ab317] text-white flex items-center justify-center shrink-0">
                <Icon name={'lucide:' + serviceIcons[i % serviceIcons.length]} class="w-6 h-6" />
              </div>
              <div>
                <h3 class="font-extrabold text-[#333] text-[19px]"><span class="text-[#7ab317]">#{i + 1}.</span> {title}</h3>
                {intro && <p class="mt-1.5 text-[14px] leading-relaxed text-[#666]">{intro}</p>}
              </div>
            </div>
            {items.length > 0 && (
              <div class="p-7 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
                {items.map(([st, sd], j) => (
                  <div class="flex gap-3">
                    <Icon name={'lucide:' + subIcons[j % subIcons.length]} class="w-5 h-5 text-[#7ab317] mt-0.5 shrink-0" />
                    <div>
                      <h4 class="font-extrabold text-[#333] text-[14px]">{st}</h4>
                      <p class="mt-1 text-[13px] leading-relaxed text-[#666]">{sd}</p>
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>
        );
      })}
    </div>
    {e.services_cta_text && (
      <div class="mt-12 text-center"><a href={e.services_cta_url || '/'} class={BTN}>{e.services_cta_text}</a></div>
    )}
  </section>

  <!-- ============== What's included ============== -->
  <section class="bg-[#f8faf3] py-20">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto">
        <p class="text-[#7ab317] font-bold text-lg">{e.included_eyebrow}</p>
        <h2 class="mt-2 text-3xl md:text-[34px] font-extrabold text-[#333]">{e.included_h2}</h2>
      </div>
      <!-- Thrive Score -->
      <div class="mt-12 rounded-3xl bg-white border border-slate-100 shadow-sm p-7 md:p-9">
        <h3 class="font-extrabold text-[#333] text-[19px]">{e.included_s1_title}</h3>
        {e.included_s1_desc && <p class="mt-2 text-[#666] text-[15px]">{e.included_s1_desc}</p>}
        <div class="mt-6 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {includedItems.map(([title, desc], i) => (
            <div class={`rounded-2xl border border-slate-100 p-5 ${includedTints[i % includedTints.length]}`}>
              <h4 class="font-extrabold text-[#333] text-[14px]">{title}</h4>
              <p class="mt-1.5 text-[13px] leading-relaxed text-[#666]">{desc}</p>
            </div>
          ))}
        </div>
        {e.included_s1_footer && <p class="mt-6 text-[#666] text-[14px] leading-relaxed">{e.included_s1_footer}</p>}
      </div>
      <!-- Plan + Worksheet -->
      <div class="mt-6 grid md:grid-cols-2 gap-6">
        {[{ t: e.included_s2_title, items: s2list }, { t: e.included_s3_title, items: s3list }].map((col) => (
          <div class="rounded-3xl bg-white border border-slate-100 shadow-sm p-7">
            <h3 class="font-extrabold text-[#333] text-[17px]">{col.t}</h3>
            <ul class="mt-4 space-y-2.5 text-[#555] text-[14px]">
              {col.items.map((l) => (<li class="flex gap-2"><span class="text-[#7ab317] font-bold shrink-0">✓</span><span>{l}</span></li>))}
            </ul>
          </div>
        ))}
      </div>
      {e.included_cta_text && (
        <div class="mt-10 text-center"><a href={e.included_cta_url || '/'} class={BTN}>{e.included_cta_text}</a></div>
      )}
    </div>
  </section>

  <!-- ============== Why choose Thrive (6 cards) ============== -->
  <section class="max-w-7xl mx-auto px-4 py-20">
    <div class="text-center max-w-3xl mx-auto">
      <p class="text-[#7ab317] font-bold text-lg">{e.whychoose_eyebrow}</p>
      <h2 class="mt-2 text-3xl md:text-[34px] font-extrabold text-[#333]">{e.whychoose_h2}</h2>
      <p class="mt-4 text-[#555] text-[15px]">{e.whychoose_body}</p>
    </div>
    <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {whychoose.map(([title, desc], i) => (
        <div class={`rounded-2xl border border-slate-100 p-7 ${whyTints[i % whyTints.length]}`}>
          <div class="w-14 h-14 rounded-2xl bg-white/70 flex items-center justify-center">
            <Icon name={'lucide:' + whychooseIcons[i % whychooseIcons.length]} class="w-7 h-7 text-[#7ab317]" />
          </div>
          <h3 class="mt-4 font-extrabold text-[#333] text-[16px]">{title}</h3>
          <p class="mt-2 text-[13px] leading-relaxed text-[#666]">{desc}</p>
        </div>
      ))}
    </div>
    {e.whychoose_cta_text && (
      <div class="mt-12 text-center"><a href={e.whychoose_cta_url || '/'} class={BTN}>{e.whychoose_cta_text}</a></div>
    )}
  </section>

  <!-- ============== FAQs ============== -->
  <section class="bg-[#f8faf3] py-20">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-center text-3xl md:text-[34px] font-extrabold text-[#333]">{e.faqs_h2}</h2>
      <div class="mt-10 divide-y divide-slate-200 border-y border-slate-200">
        {faqs.map(([q, a]) => (
          <details class="group py-4">
            <summary class="flex cursor-pointer items-center justify-between gap-4 font-extrabold text-[#333] text-[15px] list-none">
              <span>{q}</span>
              <span class="text-[#7ab317] text-xl transition-transform group-open:rotate-45 shrink-0">+</span>
            </summary>
            <p class="mt-3 text-[14px] leading-relaxed text-[#666]">{a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== Closing CTA ============== -->
  <section class="max-w-7xl mx-auto px-4 py-20">
    <div class="rounded-3xl bg-gradient-to-br from-[#86a93c] to-[#6f9230] text-white px-8 py-14 md:px-16 text-center">
      <h2 class="text-3xl md:text-4xl font-extrabold">{e.cta_h2}</h2>
      <p class="mt-4 max-w-2xl mx-auto text-white/90 text-[15px] leading-relaxed">{e.cta_text}</p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a href={e.cta_btn1_url || '/'} class={BTN}>{e.cta_btn1_text}</a>
        <a href="tel:8883420534" class="inline-flex items-center justify-center rounded-full border-2 border-white text-white hover:bg-white hover:text-[#5f8f12] transition-colors font-extrabold uppercase tracking-wide text-[13px] px-7 py-3.5">{e.cta_btn2_text}</a>
      </div>
    </div>
  </section>
</Layout>
