---
export const prerender = false; // Live SSR — Directus edits reflect on refresh

import Layout from '../../layouts/Layout.astro';
import { getDMSStrategy } from '../../lib/directus';

const d = await getDMSStrategy();

// Same parsing helpers as digital-marketing-services.astro (reused convention).
const lines = (s: string) => (s || '').split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
const paras = (s: string) => (s || '').split(/\n{2,}/).map((p) => p.trim()).filter(Boolean);
const rows = (s: string) => lines(s).map((l) => l.split('|').map((c) => c.trim()));

const allows = lines(d.allows_list);
const fail = lines(d.fail_list);
const approach = rows(d.approach_items);
const industry = rows(d.industry_items);
const focus = rows(d.focus_items);
const formula = rows(d.formula_items);
const services = lines(d.services_items);
const phases = rows(d.phases_items);
const reasons = rows(d.reasons_items);
const faqs = rows(d.faqs_items);
const included = [
  { title: d.included_s1_title, items: lines(d.included_s1_list) },
  { title: d.included_s2_title, items: lines(d.included_s2_list) },
  { title: d.included_s3_title, items: lines(d.included_s3_list) },
];
const caseStats = [
  { num: d.case_stat1_num, label: d.case_stat1_label },
  { num: d.case_stat2_num, label: d.case_stat2_label },
  { num: d.case_stat3_num, label: d.case_stat3_label },
];

// Local icon sets (copied from the Thrive theme) mapped by index.
const approachIcons = [1, 2, 3].map((n) => `/assets/dms-strategy/strategy-icon${n}.svg`);
const focusIcons = [1, 2, 3, 4, 5, 6].map((n) => `/assets/dms-strategy/digital-icon${n}.svg`);
const serviceIcons = Array.from({ length: 12 }, (_, i) => `/assets/dms-strategy/digital-approach-${i + 1}.svg`);
const reasonIcons = ['plan-icon1.svg', 'plan-icon2.svg', 'plan-icon3.svg', 'plan-icon4.svg', 'plan-icon5.svg', 'plan-icon6.png'].map((f) => `/assets/dms-strategy/${f}`);
const includedTints = ['bg-[#eef5e0]', 'bg-[#e7f1f5]', 'bg-[#fdeee0]'];
const reasonTints = ['bg-[#eef5e0]', 'bg-[#e7f1f5]', 'bg-[#fdeee0]', 'bg-[#f1ecf6]', 'bg-[#eaf3ec]', 'bg-[#fbf3d8]'];
const formulaColors = ['#7ab317', '#2fa39b', '#3b82c4', '#7c63c4', '#db7803'];

const BTN = 'inline-flex items-center justify-center rounded-full bg-[#db7803] hover:bg-[#c26a00] transition-colors text-white font-extrabold uppercase tracking-wide text-[13px] px-7 py-3.5';
---

<Layout title={d.seo_title || 'Digital Marketing Strategy Development | Thrive'} description={d.seo_description}>
  <!-- ============== Hero (centered banner with leaf decorations) ============== -->
  <section class="relative overflow-hidden bg-white">
    <div aria-hidden="true" class="pointer-events-none absolute left-0 top-0 bottom-0 w-[30%] max-w-[460px]" style="background:url(/assets/dms-strategy/subpage-header-left-corner.svg) no-repeat left bottom; background-size:contain;"></div>
    <div aria-hidden="true" class="pointer-events-none absolute right-0 top-0 bottom-0 w-[30%] max-w-[460px]" style="background:url(/assets/dms-strategy/subpage-header-right-corner.svg) no-repeat right bottom; background-size:contain;"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-4 py-20 text-center">
      <h1 class="text-4xl md:text-[52px] leading-[1.08] font-extrabold text-[#333] tracking-tight">{d.hero_h1}</h1>
      <p class="mt-4 text-lg md:text-xl text-[#5f8f12] font-semibold">{d.hero_sub}</p>
      <form action="/" method="get" class="mt-9 mx-auto max-w-2xl rounded-2xl bg-white/80 p-3 shadow-sm flex flex-col sm:flex-row gap-3">
        <div class="relative flex-1">
          <img src="/assets/menu/services/email-globe-icon.png" alt="" width="18" height="18" class="absolute left-3.5 top-1/2 -translate-y-1/2 w-[18px] h-[18px] opacity-70 pointer-events-none" />
          <input name="website" type="text" autocomplete="off" aria-label="Website address" placeholder="Enter Website Address"
            class="w-full h-[52px] rounded-xl border border-[#ddd] bg-white pl-10 pr-3 text-[15px] text-[#555] focus:outline-none focus:ring-2 focus:ring-[#7ab317]/50" />
        </div>
        <button type="submit" class={BTN + ' h-[52px] shrink-0'}>{d.hero_form_button || 'GET MY FREE PROPOSAL'}</button>
      </form>
    </div>
    <div class="relative bg-[#f3f8ea] border-y border-[#e3eecb]">
      <div class="max-w-7xl mx-auto px-4 py-3 text-center text-sm text-[#6b7280]">
        <a href="/" class="hover:text-[#7ab317]">⌂ Home</a> <span class="mx-1">/</span>
        <a href="/digital-marketing-services" class="hover:text-[#7ab317]">Digital Marketing Services</a> <span class="mx-1">/</span>
        <span class="text-[#5f8f12] font-semibold">Digital Marketing Strategy Development</span>
      </div>
    </div>
  </section>

  <!-- ============== Intro — "You Know What You Want" + video ============== -->
  <section class="max-w-[1170px] mx-auto px-5 pt-14 pb-10">
    <div class="grid lg:grid-cols-2 gap-8 items-start">
      <div>
        <h3 class="text-[26px] md:text-[30px] font-extrabold text-[#333] leading-tight mb-2.5">{d.intro_h2}</h3>
        <p class="text-[18px] font-semibold text-[#556C26] mb-5">{d.intro_sub}</p>
        {paras(d.intro_body)[0] && <p class="text-[#49453b] text-[16px] leading-relaxed">{paras(d.intro_body)[0]}</p>}
      </div>
      <!-- "The Hero Journey" video thumbnail -->
      <a href="https://www.youtube.com/watch?v=xBOf_k74_c4" target="_blank" rel="noopener" class="relative block  overflow-hidden border border-[#e3eecb] shadow-sm group">
        <img src="/assets/dms/client-journey-thumbnail.png" alt="The Hero Journey — Digital Marketing Strategy Development" width="600" height="400" class="block w-full h-auto" loading="lazy" decoding="async" />
      </a>
    </div>
    <div class="mt-6 space-y-4 text-[#49453b] text-[16px] leading-relaxed">
      {paras(d.intro_body).slice(1).map((p, i) => (<p class={i === 0 ? 'font-bold italic text-[#333]' : ''}>{p}</p>))}
    </div>
  </section>

  <!-- ============== Reviews trust strip ============== -->
  <section class="border-y border-[#e3eecb] bg-[#f3f8ea]">
    <div class="max-w-7xl mx-auto px-4 py-5 flex flex-wrap items-center justify-center gap-x-10 gap-y-4">
      <div class="flex items-center gap-2"><img src="/assets/home/google-review-icon.svg" alt="Google" class="h-7 w-auto" loading="lazy" /><span class="font-extrabold text-[#333]">150+</span><span class="text-[#f5a623]">★★★★★</span><span class="text-sm text-[#6b7280]">Reviews</span></div>
      <div class="flex items-center gap-2"><img src="/assets/home/clutch-reviewicon.svg" alt="Clutch" class="h-7 w-auto" loading="lazy" /><span class="font-extrabold text-[#333]">100+</span><span class="text-[#f5a623]">★★★★★</span><span class="text-sm text-[#6b7280]">Reviews</span></div>
      <div class="flex items-center gap-3"><img src="/assets/home/client-reviewgreen-bar.png" alt="Client reviews" class="h-9 w-auto" loading="lazy" /><span class="text-sm font-bold text-[#5f8f12]">Over 1,000 Client Reviews</span></div>
    </div>
  </section>

  <!-- ============== Why start with strategy ============== -->
  <section class="max-w-7xl mx-auto px-4 py-20">
    <div class="text-center max-w-3xl mx-auto">
      <p class="text-[#7ab317] font-bold text-lg">{d.why_eyebrow}</p>
      <h2 class="mt-2 text-3xl md:text-[34px] font-extrabold text-[#333]">{d.why_h2}</h2>
      <p class="mt-4 text-[#555] text-[15px]">{d.why_body}</p>
    </div>
    <div class="mt-12 grid lg:grid-cols-2 gap-6">
      <div class="rounded-2xl border border-[#cfe39b] bg-[#f4f9e8] overflow-hidden">
        <h3 class="bg-[#7ab317] text-white font-extrabold text-[16px] px-6 py-4">{d.allows_title}</h3>
        <ul class="p-6 grid sm:grid-cols-2 gap-x-6 gap-y-2.5 text-[#444] text-[15px]">
          {allows.map((l) => (<li class="flex gap-2"><span class="text-[#7ab317] font-bold shrink-0">✓</span><span>{l}</span></li>))}
        </ul>
      </div>
      <div class="rounded-2xl border border-[#f2cfa6] bg-[#fdf2e6] overflow-hidden">
        <h3 class="bg-[#db7803] text-white font-extrabold text-[16px] px-6 py-4">{d.fail_title}</h3>
        <ul class="p-6 grid sm:grid-cols-2 gap-x-6 gap-y-2.5 text-[#444] text-[15px]">
          {fail.map((l) => (<li class="flex gap-2"><span class="text-[#db7803] font-bold shrink-0">✕</span><span>{l}</span></li>))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ============== Guide CTA band + video ============== -->
  <section class="max-w-7xl mx-auto px-4 pb-20">
    <div class="rounded-3xl bg-gradient-to-br from-[#86a93c] to-[#6f9230] text-white px-8 py-12 md:px-14 text-center">
      <h2 class="text-2xl md:text-3xl font-extrabold">{d.guide_h2}</h2>
      <p class="mt-3 text-white/90 max-w-2xl mx-auto">{d.guide_sub}</p>
      <div class="mt-7"><a href={d.cta_band_url || '/'} class="inline-flex items-center justify-center rounded-full bg-white text-[#5f8f12] hover:bg-[#f3f8ea] transition-colors font-extrabold uppercase tracking-wide text-[13px] px-7 py-3.5">{d.cta_band_text}</a></div>
    </div>
  </section>

  <!-- ============== Strategy approach ============== -->
  <section class="bg-[#f8faf3] py-20">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto">
        <p class="text-[#7ab317] font-bold text-lg">{d.approach_eyebrow}</p>
        <h2 class="mt-2 text-3xl md:text-[34px] font-extrabold text-[#333]">{d.approach_h2}</h2>
        <p class="mt-4 text-[#555] text-[15px]">{d.approach_body}</p>
      </div>
      <div class="mt-12 grid md:grid-cols-3 gap-6">
        {approach.map(([title, desc], i) => (
          <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-7">
            <img src={approachIcons[i % approachIcons.length]} alt="" width="56" height="56" class="h-14 w-auto" loading="lazy" />
            <h3 class="mt-4 font-extrabold text-[#333] text-[17px]">{title}</h3>
            <p class="mt-2 text-[14px] leading-relaxed text-[#666]">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== Considers your industry ============== -->
  <section class="max-w-7xl mx-auto px-4 py-20">
    <div class="text-center max-w-3xl mx-auto">
      <p class="text-[#7ab317] font-bold text-lg">{d.industry_eyebrow}</p>
      <h2 class="mt-2 text-3xl md:text-[34px] font-extrabold text-[#333]">{d.industry_h2}</h2>
      <p class="mt-4 text-[#555] text-[15px]">{d.industry_body}</p>
    </div>
    <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {industry.map(([title, desc], i) => (
        <div class="flex gap-4 rounded-2xl border border-slate-100 shadow-sm p-6 hover:shadow-md transition-shadow">
          <img src={focusIcons[i % focusIcons.length]} alt="" width="40" height="40" class="h-10 w-auto shrink-0" loading="lazy" />
          <div>
            <h3 class="font-extrabold text-[#333] text-[15px]">{title}</h3>
            {desc && <p class="mt-2 text-[13px] leading-relaxed text-[#666]">{desc}</p>}
          </div>
        </div>
      ))}
    </div>
    {d.industry_footer && <p class="mt-8 text-center text-[#555] text-[15px] max-w-3xl mx-auto">{d.industry_footer}</p>}
  </section>

  <!-- ============== What's included ============== -->
  <section class="bg-[#f8faf3] py-20">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto">
        <p class="text-[#7ab317] font-bold text-lg">{d.included_eyebrow}</p>
        <h2 class="mt-2 text-3xl md:text-[34px] font-extrabold text-[#333]">{d.included_h2}</h2>
        <p class="mt-4 text-[#555] text-[15px]">{d.included_body}</p>
      </div>
      <div class="mt-12 grid md:grid-cols-3 gap-6">
        {included.map((s, i) => (
          <div class={`rounded-2xl border border-slate-100 p-6 ${includedTints[i % includedTints.length]}`}>
            <h3 class="font-extrabold text-[#333] text-[15px]">{s.title}</h3>
            <ul class="mt-3 space-y-2 text-[#555] text-[14px]">
              {s.items.map((l) => (<li class="flex gap-2"><span class="text-[#7ab317] font-bold shrink-0">✓</span><span>{l}</span></li>))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== Case study ============== -->
  <section class="max-w-7xl mx-auto px-4 py-20">
    <div class="text-center max-w-3xl mx-auto">
      <p class="text-[#7ab317] font-bold text-lg">{d.case_eyebrow}</p>
      <h2 class="mt-2 text-3xl md:text-[34px] font-extrabold text-[#333]">{d.case_h2}</h2>
      <div class="mt-4 space-y-3 text-[#555] text-[15px]">{paras(d.case_body).map((p) => <p>{p}</p>)}</div>
    </div>
    <div class="mt-10 rounded-3xl bg-[#403C33] text-white px-8 py-10 md:px-14">
      <span class="inline-block text-[#a9c764] font-extrabold uppercase tracking-wide text-xs">{d.case_label}</span>
      <div class="mt-6 grid sm:grid-cols-3 gap-8 text-center">
        {caseStats.map((s) => (
          <div><div class="text-4xl font-extrabold text-[#a9c764]">{s.num}</div><div class="mt-1 text-sm text-white/80">{s.label}</div></div>
        ))}
      </div>
      {d.case_desc && <p class="mt-8 text-white/85 text-[15px] leading-relaxed max-w-3xl">{d.case_desc}</p>}
    </div>
  </section>

  <!-- ============== 6 key areas of focus ============== -->
  <section class="bg-[#f8faf3] py-20">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto">
        <p class="text-[#7ab317] font-bold text-lg">{d.focus_eyebrow}</p>
        <h2 class="mt-2 text-3xl md:text-[34px] font-extrabold text-[#333]">{d.focus_pre_h2}</h2>
        <h3 class="mt-3 text-xl font-extrabold text-[#5f8f12]">{d.focus_h2}</h3>
        <p class="mt-4 text-[#555] text-[15px]">{d.focus_body}</p>
      </div>
      <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {focus.map(([title, desc], i) => (
          <div class="relative bg-white rounded-2xl border border-slate-100 shadow-sm p-7">
            <span class="absolute top-5 right-6 text-3xl font-extrabold text-[#eef0e6]">{i + 1}</span>
            <img src={focusIcons[i % focusIcons.length]} alt="" width="48" height="48" class="h-12 w-auto" loading="lazy" />
            <h4 class="mt-4 font-extrabold text-[#333]">{title}</h4>
            <p class="mt-2 text-[13px] leading-relaxed text-[#666]">{desc}</p>
          </div>
        ))}
      </div>
      {d.focus_footer && <p class="mt-8 text-center text-[#555] text-[15px] max-w-3xl mx-auto">{d.focus_footer}</p>}
    </div>
  </section>

  <!-- ============== Growth formula (numbered stepper) ============== -->
  <section class="max-w-7xl mx-auto px-4 py-20">
    <div class="text-center max-w-3xl mx-auto">
      <p class="text-[#7ab317] font-bold text-lg">{d.formula_eyebrow}</p>
      <h2 class="mt-2 text-3xl md:text-[34px] font-extrabold text-[#333]">{d.formula_h2}</h2>
      <p class="mt-4 text-[#555] text-[15px]">{d.formula_body}</p>
    </div>
    <!-- stepper -->
    <div class="mt-12 flex flex-wrap items-center justify-center gap-x-2 gap-y-4">
      {formula.map(([title], i) => (
        <div class="flex items-center">
          <div class="flex flex-col items-center w-28 text-center">
            <span class="w-12 h-12 rounded-full text-white font-extrabold flex items-center justify-center" style={`background:${formulaColors[i % formulaColors.length]}`}>{i + 1}</span>
            <span class="mt-2 font-extrabold text-[#333] uppercase tracking-wide text-xs">{title}</span>
          </div>
          {i < formula.length - 1 && <span class="hidden sm:block w-8 h-[3px] bg-slate-200 mb-6"></span>}
        </div>
      ))}
    </div>
    <div class="mt-12 grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {formula.map(([title, desc], i) => (
        <div class="rounded-2xl border-t-4 bg-white shadow-sm p-6" style={`border-color:${formulaColors[i % formulaColors.length]}`}>
          <h3 class="font-extrabold text-[#333] uppercase tracking-wide text-sm">{i + 1}. {title}</h3>
          <p class="mt-2 text-[13px] leading-relaxed text-[#666]">{desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ============== Strategy services ============== -->
  <section class="bg-[#f8faf3] py-20">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto">
        <p class="text-[#7ab317] font-bold text-lg">{d.services_eyebrow}</p>
        <h2 class="mt-2 text-3xl md:text-[34px] font-extrabold text-[#333]">{d.services_h2}</h2>
        <p class="mt-4 text-[#555] text-[15px]">{d.services_body}</p>
      </div>
      <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {services.map((title, i) => (
          <div class="flex items-center gap-4 bg-white rounded-xl border border-slate-100 shadow-sm px-5 py-4 hover:shadow-md transition-shadow">
            <img src={serviceIcons[i % serviceIcons.length]} alt="" width="36" height="36" class="h-9 w-auto shrink-0" loading="lazy" />
            <h3 class="font-extrabold text-[#333] text-[15px]">{title}</h3>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== Process (money tree phases) ============== -->
  <section class="max-w-7xl mx-auto px-4 py-20">
    <div class="text-center max-w-3xl mx-auto">
      <p class="text-[#7ab317] font-bold text-lg">{d.process_eyebrow}</p>
      <h2 class="mt-2 text-3xl md:text-[34px] font-extrabold text-[#333]">{d.process_h2}</h2>
      <p class="mt-4 text-[#555] text-[15px]">{d.process_body}</p>
    </div>
    <div class="mt-12 grid md:grid-cols-3 gap-6">
      {phases.map(([phase, subtitle, desc]) => (
        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-7 flex flex-col">
          <span class="text-[#5f8f12] font-extrabold uppercase tracking-wide text-sm">{phase}</span>
          <h3 class="mt-2 font-extrabold text-[#333] text-[18px]">{subtitle}</h3>
          <p class="mt-3 text-[14px] leading-relaxed text-[#666]">{desc}</p>
        </div>
      ))}
    </div>
    {d.process_footer && <p class="mt-10 text-center text-[#555] text-[15px] max-w-3xl mx-auto">{d.process_footer}</p>}
  </section>

  <!-- ============== Why choose Thrive ============== -->
  <section class="bg-[#f8faf3] py-20">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto">
        <p class="text-[#7ab317] font-bold text-lg">{d.whychoose_eyebrow}</p>
        <h2 class="mt-2 text-3xl md:text-[34px] font-extrabold text-[#333]">{d.whychoose_h2}</h2>
        <p class="mt-4 text-[#555] text-[15px]">{d.whychoose_body}</p>
      </div>
      <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {reasons.map(([title, desc], i) => (
          <div class={`rounded-2xl border border-slate-100 p-7 ${reasonTints[i % reasonTints.length]}`}>
            <img src={reasonIcons[i % reasonIcons.length]} alt="" width="48" height="48" class="h-12 w-auto" loading="lazy" />
            <h3 class="mt-4 font-extrabold text-[#333]">{title}</h3>
            {desc && <p class="mt-2 text-[13px] leading-relaxed text-[#666]">{desc}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== FAQs ============== -->
  <section class="max-w-3xl mx-auto px-4 py-20">
    <h2 class="text-center text-3xl md:text-[34px] font-extrabold text-[#333]">{d.faqs_h2}</h2>
    <div class="mt-10 divide-y divide-slate-200 border-y border-slate-200">
      {faqs.map(([q, a]) => (
        <details class="group py-4">
          <summary class="flex cursor-pointer items-center justify-between gap-4 font-extrabold text-[#333] text-[15px] list-none">
            <span>{q}</span>
            <span class="text-[#7ab317] text-xl transition-transform group-open:rotate-45 shrink-0">+</span>
          </summary>
          <p class="mt-3 text-[14px] leading-relaxed text-[#666]">{a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- ============== Closing CTA ============== -->
  <section class="max-w-7xl mx-auto px-4 pb-20">
    <div class="rounded-3xl bg-gradient-to-br from-[#86a93c] to-[#6f9230] text-white px-8 py-14 md:px-16 text-center">
      <h2 class="text-3xl md:text-4xl font-extrabold">{d.cta_h2}</h2>
      <p class="mt-4 max-w-2xl mx-auto text-white/90 text-[15px] leading-relaxed">{d.cta_text}</p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a href={d.cta_btn1_url || '/'} class={BTN}>{d.cta_btn1_text}</a>
        <a href="tel:8883420534" class="inline-flex items-center justify-center rounded-full border-2 border-white text-white hover:bg-white hover:text-[#5f8f12] transition-colors font-extrabold uppercase tracking-wide text-[13px] px-7 py-3.5">{d.cta_btn2_text}</a>
      </div>
