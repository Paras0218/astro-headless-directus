---
interface Props {
  heading?: string;
  nameLabel?: string;
  emailLabel?: string;
  websiteLabel?: string;
  messageLabel?: string;
  buttonLabel?: string;
  successMessage?: string;
}
const {
  heading = 'Get Your Free Proposal',
  nameLabel = 'Full Name*',
  emailLabel = 'Email Address*',
  websiteLabel = 'Website URL',
  messageLabel = 'Message',
  buttonLabel = 'Request Proposal',
  successMessage = 'Success! Our growth experts will look into this.',
} = Astro.props;
---
<div class="bg-white p-8 rounded-2xl shadow-xl border border-slate-100 w-full max-w-md mx-auto">
  <h3 class="text-2xl font-bold text-slate-900 mb-6">{heading}</h3>
  <form id="agencyLeadForm" class="space-y-4">
    <div>
      <label class="block text-sm font-semibold text-slate-700 mb-1">{nameLabel}</label>
      <input type="text" name="name" required class="w-full px-4 py-2 rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-orange-500 text-black" placeholder="John Doe" />
    </div>
    <div>
      <label class="block text-sm font-semibold text-slate-700 mb-1">{emailLabel}</label>
      <input type="email" name="email" required class="w-full px-4 py-2 rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-orange-500 text-black" placeholder="john@example.com" />
    </div>
    <div>
      <label class="block text-sm font-semibold text-slate-700 mb-1">{websiteLabel}</label>
      <input type="url" name="website" class="w-full px-4 py-2 rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-orange-500 text-black" placeholder="https://example.com" />
    </div>
    <div>
      <label class="block text-sm font-semibold text-slate-700 mb-1">{messageLabel}</label>
      <textarea name="message" rows="4" class="w-full px-4 py-2 rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-orange-500 text-black" placeholder="Tell us about your objectives..."></textarea>
    </div>
    <button type="submit" class="w-full bg-orange-600 hover:bg-orange-700 text-white font-bold py-3 px-4 rounded-lg transition-colors duration-200 shadow-md">
      {buttonLabel}
    </button>
  </form>
  <div id="formFeedback" class="mt-4 text-center text-sm font-medium hidden"></div>
</div>

<script is:inline define:vars={{ successMessage }}>
  // NOTE: define:vars makes this an inline script (not bundled/transpiled),
  // so it must be plain JavaScript — no TypeScript syntax here.
  const form = document.getElementById('agencyLeadForm');
  const feedback = document.getElementById('formFeedback');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!feedback) return;

    feedback.classList.remove('hidden', 'text-green-600', 'text-red-600');
    feedback.innerText = 'Sending request...';
    feedback.classList.add('text-slate-600');

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      const response = await fetch('/api/lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      const result = await response.json();

      if (response.ok && result.success) {
        feedback.className = 'mt-4 text-center text-sm font-medium text-green-600';
        feedback.innerText = successMessage;
        form.reset();
      } else {
        throw new Error(result.error || 'Submission failed');
      }
    } catch (err) {
      feedback.className = 'mt-4 text-center text-sm font-medium text-red-600';
      feedback.innerText = 'Error: ' + err.message;
    }
  });
</script>
