<style>
  /* Self-contained: vars + .wrap + .btn baked in so the footer looks right on
     any page, including Layout pages that don't load public/styles.css. */
  .site-footer {
    --thrive-orange: #D87928;
    --thrive-orange-dark: #b56120;
    --ink: #443F34;
    --ink-soft: #3a3a3a;
    position: relative;
    background: #403C33;
    color: #f6f1e6;
    padding: 0;
    overflow: hidden;
    isolation: isolate;
    border-top: none;
    font-size: 16px;
    font-family: inherit;
  }
  .site-footer .wrap { max-width: 1240px; margin: 0 auto; padding: 0 24px; display: block; }
  .site-footer .btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    height: 56px; padding: 0 30px; border-radius: 999px;
    font-family: inherit; font-weight: 700; font-size: 15px; letter-spacing: 0.01em;
    border: 0; cursor: pointer; text-decoration: none; white-space: nowrap;
    transition: transform .15s ease, background .15s ease, color .15s ease;
  }
  .site-footer .btn-primary { background: var(--thrive-orange); color: #fff; }
  .site-footer .btn-primary:hover { background: var(--thrive-orange-dark); transform: translateY(-1px); color: #fff; }

  .footer-bg {
    position: absolute; top: 50%; right: -120px; transform: translateY(-50%);
    width: 620px; height: 620px; pointer-events: none; z-index: 0; opacity: 1; display: block;
  }
  .footer-bg img {
    width: 100%; height: 100%; object-fit: contain;
    filter: brightness(0) saturate(100%) invert(22%) sepia(8%) saturate(900%) hue-rotate(10deg) brightness(95%) contrast(85%);
    opacity: .55;
  }
  .footer-main { position: relative; z-index: 1; padding: 64px 24px 40px; }
  .footer-grid { display: grid; grid-template-columns: 1.05fr 1.4fr 0.95fr; gap: 56px; align-items: start; }

  .footer-brand .footer-logo { display: inline-block; line-height: 0; margin-bottom: 18px; }
  .footer-brand .footer-logo svg { display: block; height: 56px; width: auto; }
  .footer-h2 { color: #fff; font-size: clamp(34px, 3.4vw, 44px); line-height: 1.05; letter-spacing: -0.025em; font-weight: 800; margin: 0 0 22px; }
  .footer-h2 em { font-style: normal; font-weight: 800; color: #7D963D; }
  .footer-desc { color: rgba(246,241,230,.78); font-size: 14px; line-height: 1.65; margin: 0 0 26px; max-width: 460px; }
  .footer-desc strong { color: #fff; font-weight: 700; }
  .footer-social { list-style: none; padding: 0; margin: 0; display: flex; gap: 10px; }
  .footer-social a {
    display: inline-flex; align-items: center; justify-content: center;
    width: 30px; height: 30px; border-radius: 50%; background: rgba(255,255,255,.08); color: #f6f1e6;
    transition: background-color 160ms ease, transform 160ms ease, color 160ms ease;
  }
  .footer-social a:hover { background: #7D963D; color: #2f3e0f; transform: translateY(-1px); }
  .footer-social a:focus-visible { outline: 2px solid #7D963D; outline-offset: 2px; }

  .footer-cities { padding-top: 78px; }
  .cities-label { display: flex; align-items: center; gap: 8px; color: #7D963D; font-size: 14px; font-weight: 700; margin: 0 0 22px; }
  .cities-label svg { display: inline-block; }
  .cities-grid { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px 24px; }
  .cities-grid li { margin: 0; }
  .cities-grid a { color: rgba(246,241,230,.85); font-size: 14px; font-weight: 400; text-decoration: none; transition: color 140ms ease; }
  .cities-grid a:hover { color: #7D963D; }
  .cities-grid a:focus-visible { outline: 2px solid #7D963D; outline-offset: 2px; border-radius: 2px; }

  .footer-cta { padding-top: 56px; }
  .cta-card {
    position: relative; background: #fff; border-radius: 18px; padding: 26px 28px 28px;
    color: var(--ink); box-shadow: 0 30px 50px -28px rgba(0,0,0,.45); overflow: hidden; isolation: isolate; min-height: 240px;
  }
  .cta-content { position: relative; z-index: 2; display: flex; flex-direction: column; align-items: flex-start; }
  .cta-h3 { color: var(--ink); font-size: 22px; font-weight: 800; letter-spacing: -0.01em; margin: 0 0 10px; }
  .cta-text { color: var(--ink-soft); font-size: 14px; line-height: 1.5; margin: 0 0 18px; max-width: 220px; }
  .cta-btn { height: 42px; padding: 0 22px; font-size: 13px; line-height: 1; margin-bottom: 16px; letter-spacing: 0.04em; }
  .cta-phone { display: inline-block; color: var(--thrive-orange); font-weight: 700; font-size: 19px; letter-spacing: -0.005em; text-decoration: none; transition: color 140ms ease; position: relative; z-index: 3; }
  .cta-phone:hover { color: var(--thrive-orange-dark); }
  .cta-tree { position: absolute; right: -34px; bottom: -28px; width: 140px; height: 140px; pointer-events: none; z-index: 0; opacity: 1; }
  .cta-tree img { width: 100%; height: 100%; object-fit: contain; }

  .footer-bottom { position: relative; z-index: 1; padding: 22px 24px 28px; border-top: 1px solid rgba(246,241,230,.12); }
  .footer-bottom p { margin: 0; color: rgba(246,241,230,.7); font-size: 13px; line-height: 1.6; display: flex; flex-wrap: wrap; align-items: center; gap: 0 6px; }
  .footer-bottom a { color: rgba(246,241,230,.7); text-decoration: none; transition: color 140ms ease; }
  .footer-bottom a:hover { color: #7D963D; }
  .footer-bottom .sep { color: rgba(246,241,230,.32); margin: 0 4px; }

  @media (max-width: 980px) {
    .footer-grid { grid-template-columns: 1fr; gap: 48px; }
    .footer-cities { padding-top: 0; }
    .footer-cta { padding-top: 0; max-width: 380px; }
    .footer-desc { max-width: none; }
    .footer-bg { width: 360px; opacity: .05; right: -120px; }
  }
  @media (max-width: 640px) {
    .footer-main { padding: 48px 24px 32px; }
    .footer-h2 { font-size: 32px; }
    .cities-grid { grid-template-columns: repeat(2, 1fr); gap: 12px 18px; }
    .footer-bottom p { font-size: 12px; gap: 0 4px; }
    .footer-bottom .sep { margin: 0 2px; }
  }
</style>
