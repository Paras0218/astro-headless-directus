24.636-7.6-26.732-22.54h81.798l-.022-.233zM369.65 381.4c-17.304-1.3-31.98 18.87-31.98 18.87s-4.718-17.822-35.65-25.954c12.587 4.193 18.877 41.155 18.877 41.155V543.9h32.76V418.345c.5-6.3 2.884-30.664 15.994-36.954z"/>
            <path fill="#7D963D" d="M379.086 301.965s9.697 22.54 2.358 42.5-28.836 29.615-28.836 29.615-9.697-22.54-2.358-42.458 28.836-29.657 28.836-29.657zm50.064-25.685s3.932 21.25-6.027 37.478c-9.967 15.994-29.885 20.712-29.885 20.712s-3.932-21.25 6.028-37.485c9.96-15.987 29.884-20.705 29.884-20.705zm-66.058-36.174s9.966 19.394 5.24 37.485c-4.717 18.346-22.54 28.588-22.54 28.588s-9.96-19.394-5.24-37.485c4.98-18.104 22.54-28.588 22.54-28.588zm-128.96 57.142s20.967-5.242 37.747 3.67 22.54 28.574 22.54 28.574-20.967 5.242-37.747-3.67c-16.5-8.918-22.54-28.574-22.54-28.574zM393.5 256.094s5.767 13.628 1.835 25.953c-4.193 12.318-16.773 18.346-16.773 18.346s-5.766-13.628-1.834-25.946c4.192-12.063 16.772-18.353 16.772-18.353zm-126.076 8.648s14.415 2.125 22.54 12.042c8.125 9.697 6.814 23.587 6.814 23.587s-14.415-2.125-22.54-12.042-6.814-23.587-6.814-23.587zm41.41-27.782s15.47 10.22 19.664 25.946-4.96 30.67-4.96 30.67-15.5-10.22-19.663-25.954c-3.953-15.462 4.958-30.663 4.958-30.663zm141.284 95.152s-4.193 24.083-23.85 35.905c-19.4 11.8-46.92 7.083-46.92 7.083s4.193-24.083 23.85-35.905c19.678-12.063 46.92-7.083 46.92-7.083zm-31.72 66.576s-14.167 8.9-27.78 5.503-22.015-17.82-22.015-17.82 14.167-8.918 27.78-5.504S418.4 398.69 418.4 398.69zM308.3 289.647s24.38 13.366 31.166 38-6.3 50.844-6.3 50.844S308.786 365.135 302 340.5c-6.814-24.4 6.3-50.85 6.3-50.85zm-82.816 56.355s24.083-12.58 46.92-6.552 35.643 28.333 35.643 28.333-24.083 12.587-46.913 6.552-35.65-28.333-35.65-28.333zm28.808 50.328s10.5-14.676 25.954-17.035c15.463-2.125 29.615 9.173 29.615 9.173s-10.483 14.677-25.946 17.035c-15.457 2.097-29.623-9.173-29.623-9.173z"/>
