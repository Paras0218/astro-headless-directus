// singleton footer_* fields) so any page can drop in <SiteFooter /> with no props.
// Self-contained styles (vars + .wrap + .btn baked in) so it also works on Layout
// pages that don't load the homepage's public/styles.css.
import { getHomepage } from '../lib/directus';
const home = await getHomepage();
